<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <!-- hello testing 4th line -->
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Tarkov Visual Quest Tracker</title>
  <style>
    :root { color-scheme: dark; }
    * { box-sizing: border-box; }
    body { margin: 0; font-family: Arial, sans-serif; background: #000; color: #fff; }
    .wrap { max-width: 1800px; margin: 0 auto; padding: 16px; }
    .panel { border: 1px solid rgba(255,255,255,0.1); border-radius: 24px; background: #09090b; box-shadow: 0 20px 40px rgba(0,0,0,0.4); padding: 20px; }
    .row { display: flex; flex-wrap: wrap; gap: 10px; align-items: center; }
    .spacer { margin-left: auto; display: flex; gap: 8px; flex-wrap: wrap; }
    button, .file-label { border: 1px solid rgba(255,255,255,0.1); border-radius: 12px; background: #18181b; color: #fff; padding: 10px 14px; cursor: pointer; font-size: 14px; }
    .badge { border-radius: 12px; padding: 6px 10px; font-size: 14px; }
    .traders { display: grid; grid-template-columns: repeat(auto-fill, minmax(130px, 1fr)); gap: 10px; margin: 14px 0; padding: 12px; border-radius: 18px; border: 1px solid rgba(255,255,255,0.1); background: rgba(24,24,27,0.7); }
    .trader { border-radius: 12px; border: 1px solid rgba(255,255,255,0.1); padding: 8px; text-align: left; background: #09090b; }
    .trader.active { border-color: #d946ef; box-shadow: 0 8px 18px rgba(217,70,239,0.2); }
    .muted { color: #a1a1aa; font-size: 13px; }
    .title { font-size: 28px; margin: 0; }
    .view { position: relative; height: 70vh; overflow: hidden; border-radius: 20px; border: 1px solid rgba(255,255,255,0.1); background: #020817; margin-top: 10px; }
    .canvas { position: absolute; left: 0; top: 0; transform-origin: top left; cursor: grab; }
    .canvas.dragging { cursor: grabbing; }
    .node { position: absolute; width: 180px; min-height: 74px; border-radius: 12px; padding: 10px 12px; text-align: left; white-space: pre-wrap; line-height: 1.2; font-size: 14px; font-weight: 700; user-select: none; }
    .completed { border: 1px solid #22c55e; background: rgba(22,163,74,0.2); color: #dcfce7; }
    .available { border: 1px solid #f97316; background: rgba(249,115,22,0.2); color: #ffedd5; }
    .locked { border: 1px solid #ef4444; background: rgba(185,28,28,0.2); color: #fee2e2; }
    #fileInput { display: none; }
  </style>
</head>
<body>
  <div class="wrap">
    <div class="panel">
      <div class="row">
        <span class="badge" style="background:rgba(255,255,255,0.1)">Green = done</span>
        <span class="badge" style="background:rgba(249,115,22,0.2);color:#fed7aa">Orange = available</span>
        <span class="badge" style="background:rgba(220,38,38,0.2);color:#fecaca">Red = locked</span>
        <div class="spacer">
          <button id="zoomIn">+ Zoom In</button>
          <button id="zoomOut">- Zoom Out</button>
          <button id="resetView">Reset View</button>
          <button id="exportBtn">Export</button>
          <label class="file-label" for="fileInput">Import</label>
          <input id="fileInput" type="file" accept="application/json">
          <button id="resetAll">Reset All</button>
        </div>
      </div>
      <div id="traders" class="traders"></div>
      <h1 id="title" class="title"></h1>
      <div class="muted">Progress saves automatically in this browser. No install required.</div>
      <div id="view" class="view">
        <div class="canvas" id="canvas">
          <svg id="edges" style="position:absolute;left:0;top:0"></svg>
          <div id="nodes" style="position:absolute;left:0;top:0;width:100%;height:100%"></div>
        </div>
      </div>
    </div>
  </div>

