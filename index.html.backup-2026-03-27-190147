        {"id":"tt-261","name":"Shipping Delay - Part 4","requires":["tt-260"]},
        {"id":"tt-262","name":"Shipping Delay - Part 5","requires":["tt-261"]}
      ]
    };

    const questLookup = Object.fromEntries(Object.values(FALLBACK_QUESTS_BY_TRADER).flat().map((q) => [q.id, q]));
    const state = { activeTrader: "Prapor", progress: loadProgress(), zoom: 0.75, offset: { x: 0, y: 0 }, dragging: false, dragStart: { x: 0, y: 0 } };

    function normalizeProgress(raw) {
      if (!raw || typeof raw !== "object") return {};
      const n = {};
      Object.entries(raw).forEach(([id, value]) => {
        if (value === true) n[id] = { state: "manual" };
        else if (value && typeof value === "object" && (value.state === "manual" || value.state === "auto")) n[id] = value;
      });
      return n;
    }
    function loadProgress() {
      try { const raw = localStorage.getItem(STORAGE_KEY); return raw ? normalizeProgress(JSON.parse(raw)) : {}; }
      catch { return {}; }
    }
    function saveProgress() { localStorage.setItem(STORAGE_KEY, JSON.stringify(state.progress)); }
    function getStatus(quest) {
      if (state.progress[quest.id]) return "completed";
      return quest.requires.every((dep) => !!state.progress[dep]) ? "available" : "locked";
    }
    function fitText(name) {
      if (name.length < 16) return name;
      const words = name.split(" ");
      if (words.length < 2) return name;
      const mid = Math.ceil(words.length / 2);
      return [words.slice(0, mid).join(" "), words.slice(mid).join(" ")].join("\n");
    }
    function expandAutoCompletions(sourceId, visited = new Set()) {
      if (visited.has(sourceId)) return [];
      visited.add(sourceId);
      const quest = questLookup[sourceId];
      if (!quest || !Array.isArray(quest.completes)) return [];
      const direct = [...quest.completes];
      const nested = quest.completes.flatMap((id) => expandAutoCompletions(id, visited));
      return [...new Set([...direct, ...nested])];
    }
    function recomputeProgressFromManual(manualIds) {
      const manual = new Set(manualIds);
      let changed = true;
      while (changed) {
        changed = false;
        for (const id of [...manual]) {
          const q = questLookup[id];
          const ok = q && (q.requires || []).every((dep) => manual.has(dep));
          if (!ok) { manual.delete(id); changed = true; }
        }
      }
      const result = {};
      manual.forEach((id) => { result[id] = { state: "manual" }; });
      for (const sourceId of manual) {
        const targets = expandAutoCompletions(sourceId);
        targets.forEach((targetId) => {
          if (result[targetId]) return;
          const target = questLookup[targetId];
          if (!target) return;
          const depsOk = target.requires.every((dep) => !!result[dep]);
          if (depsOk) result[targetId] = { state: "auto", source: sourceId };
        });
      }
      return result;
    }
    function buildAutoLayout(quests) {
      const NODE_W = 180, NODE_H = 74, H_GAP = 110, V_GAP = 26, ROOT_GAP = 50, LEFT_PAD = 60, TOP_PAD = 50;
      const byId = Object.fromEntries(quests.map((q) => [q.id, q]));
      const children = {}; quests.forEach((q) => { children[q.id] = []; });
      quests.forEach((q) => q.requires.forEach((dep) => { if (children[dep]) children[dep].push(q.id); }));
      const depthMemo = {};
      function depth(id) { if (depthMemo[id] !== undefined) return depthMemo[id]; const q = byId[id]; if (!q || q.requires.length === 0) return depthMemo[id] = 0; return depthMemo[id] = Math.max(...q.requires.map(depth)) + 1; }
      quests.forEach((q) => depth(q.id));
      const subtreeMemo = {};
      function subtree(id) {
        if (subtreeMemo[id] !== undefined) return subtreeMemo[id];
        const kids = [...children[id]].sort((a,b) => depth(a)-depth(b) || a.localeCompare(b));
        if (kids.length === 0) return subtreeMemo[id] = NODE_H;
        const total = kids.reduce((s, kid, i) => s + subtree(kid) + (i ? V_GAP : 0), 0);
        return subtreeMemo[id] = Math.max(NODE_H, total);
      }
      const roots = quests.filter((q) => q.requires.length === 0).map((q) => q.id);
      roots.forEach((id) => subtree(id));
      const orderedRoots = [...roots].sort((a,b) => subtree(b)-subtree(a) || a.localeCompare(b));
      const positions = {};
      function place(id, top) {
        const kids = [...children[id]].sort((a,b) => depth(a)-depth(b) || a.localeCompare(b));
        const h = subtree(id);
        positions[id] = { x: LEFT_PAD + depth(id) * (NODE_W + H_GAP), y: top + h / 2 - NODE_H / 2 };
        let cursor = top;
        kids.forEach((kid, i) => { const kh = subtree(kid); place(kid, cursor); cursor += kh + (i < kids.length - 1 ? V_GAP : 0); });
      }
      let cursor = TOP_PAD;
      orderedRoots.forEach((id, i) => { const h = subtree(id); place(id, cursor); cursor += h + (i < orderedRoots.length - 1 ? ROOT_GAP : 0); });
      const maxX = Math.max(...Object.values(positions).map((p) => p.x), LEFT_PAD) + NODE_W + LEFT_PAD;
      const maxY = Math.max(...Object.values(positions).map((p) => p.y), TOP_PAD) + NODE_H + TOP_PAD;
      return { positions, width: maxX, height: Math.max(maxY, 520), nodeWidth: NODE_W, nodeHeight: NODE_H };
    }
    function toggleQuest(quest) {
      const status = getStatus(quest);
      const manual = new Set(Object.entries(state.progress).filter(([,v]) => v && v.state === "manual").map(([id]) => id));
      if (status === "completed") {
        const v = state.progress[quest.id];
        if (!v || v.state !== "manual") return;
        manual.delete(quest.id);
      } else if (status === "available") {
        manual.add(quest.id);
      } else return;
      state.progress = recomputeProgressFromManual(manual);
      saveProgress();
      render();
    }
    function render() {
      const title = document.getElementById("title");
      const tradersEl = document.getElementById("traders");
      const canvas = document.getElementById("canvas");
      const edges = document.getElementById("edges");
      const nodes = document.getElementById("nodes");
      const quests = FALLBACK_QUESTS_BY_TRADER[state.activeTrader] || [];
      const layout = buildAutoLayout(quests);
      title.textContent = state.activeTrader;
      tradersEl.innerHTML = "";
      TRADERS.forEach((trader) => {
        const id = trader.id;
        const traderQuests = FALLBACK_QUESTS_BY_TRADER[id] || [];
        const completed = traderQuests.filter((q) => state.progress[q.id]).length;
        const btn = document.createElement("button");
        btn.className = "trader" + (id === state.activeTrader ? " active" : "");
        btn.innerHTML =
          "<img src='" + trader.img + "' alt='" + id + "' referrerpolicy='no-referrer' crossorigin='anonymous' style='height:76px;width:100%;object-fit:cover;border-radius:8px' />" +
          "<div style='font-weight:700;margin-top:8px'>" + id + "</div>" +
          "<div class='muted'>" + completed + "/" + traderQuests.length + " done</div>";
        const img = btn.querySelector("img");
        img.onerror = function () {
          this.style.display = "none";
          const fallback = document.createElement("div");
          fallback.style.height = "76px";
          fallback.style.width = "100%";
          fallback.style.borderRadius = "8px";
          fallback.style.display = "flex";
          fallback.style.alignItems = "center";
          fallback.style.justifyContent = "center";
          fallback.style.background = "linear-gradient(135deg, #27272a, #09090b)";
          fallback.style.color = "#e4e4e7";
          fallback.style.fontSize = "13px";
          fallback.style.fontWeight = "700";
          fallback.textContent = id;
          btn.prepend(fallback);
        };
        btn.onclick = () => { state.activeTrader = id; state.zoom = 0.75; state.offset = { x: 0, y: 0 }; render(); };
        tradersEl.appendChild(btn);
      });
      canvas.style.width = layout.width + "px";
      canvas.style.height = layout.height + "px";
      canvas.style.transform = "translate(" + state.offset.x + "px," + state.offset.y + "px) scale(" + state.zoom + ")";
      edges.setAttribute("width", layout.width);
      edges.setAttribute("height", layout.height);
      edges.innerHTML = "";
      quests.forEach((quest) => {
        quest.requires.forEach((depId) => {
          const dep = layout.positions[depId];
          const q = layout.positions[quest.id];
          if (!dep || !q) return;
          const x1 = dep.x + layout.nodeWidth, y1 = dep.y + layout.nodeHeight / 2;
          const x2 = q.x, y2 = q.y + layout.nodeHeight / 2;
          const path = document.createElementNS("http://www.w3.org/2000/svg", "path");
          path.setAttribute("d", "M " + x1 + " " + y1 + " C " + (x1 + 60) + " " + y1 + ", " + (x2 - 60) + " " + y2 + ", " + x2 + " " + y2);
          path.setAttribute("fill", "none");
          path.setAttribute("stroke", "rgba(96, 165, 250, 0.55)");
          path.setAttribute("stroke-width", "2.5");
          edges.appendChild(path);
        });
      });
      nodes.innerHTML = "";
      quests.forEach((quest) => {
        const pos = layout.positions[quest.id];
        if (!pos) return;
        const status = getStatus(quest);
        const btn = document.createElement("button");
        btn.className = "node " + status;
        btn.style.left = pos.x + "px";
        btn.style.top = pos.y + "px";
        btn.title = quest.name;
        btn.textContent = fitText(quest.name);
        btn.onclick = (e) => { e.stopPropagation(); toggleQuest(quest); };
        nodes.appendChild(btn);
      });
    }
    document.getElementById("zoomIn").onclick = () => { state.zoom = Math.min(1.35, state.zoom + 0.08); render(); };
    document.getElementById("zoomOut").onclick = () => { state.zoom = Math.max(0.35, state.zoom - 0.08); render(); };
    document.getElementById("resetView").onclick = () => { state.zoom = 0.75; state.offset = { x: 0, y: 0 }; render(); };
    document.getElementById("resetAll").onclick = () => { state.progress = {}; saveProgress(); render(); };
    document.getElementById("exportBtn").onclick = () => {
      const blob = new Blob([JSON.stringify(state.progress, null, 2)], { type: "application/json" });
      const url = URL.createObjectURL(blob);
      const a = document.createElement("a");
      a.href = url; a.download = "tarkov-quest-progress.json"; a.click();
      URL.revokeObjectURL(url);
    };
    document.getElementById("fileInput").onchange = (event) => {
      const file = event.target.files && event.target.files[0];
      if (!file) return;
      const reader = new FileReader();
      reader.onload = () => {
        try {
          const parsed = JSON.parse(String(reader.result || "{}"));
          const normalized = normalizeProgress(parsed);
          const manualIds = Object.entries(normalized).filter(([,v]) => v && v.state === "manual").map(([id]) => id);
          state.progress = recomputeProgressFromManual(manualIds);
          saveProgress();
          render();
        } catch { alert("Could not read progress file."); }
      };
      reader.readAsText(file);
      event.target.value = "";
    };
    const view = document.getElementById("view");
    const canvas = document.getElementById("canvas");
    canvas.addEventListener("mousedown", (e) => {
      state.dragging = true;
      state.dragStart = { x: e.clientX - state.offset.x, y: e.clientY - state.offset.y };
      canvas.classList.add("dragging");
    });
    view.addEventListener("mousemove", (e) => {
      if (!state.dragging) return;
      state.offset = { x: e.clientX - state.dragStart.x, y: e.clientY - state.dragStart.y };
      render();
    });
    ["mouseup", "mouseleave"].forEach((evt) => view.addEventListener(evt, () => {
      state.dragging = false;
      canvas.classList.remove("dragging");
    }));
    render();
  </script>
